; Godot 4.6 - Fare Simulatoru Terrain projesi
; Engine yapilandirma dosyasi

config_version=5

[application]

config/name="Fare Simulatoru Terrain"
config/description="Terrain3D tabanli arazi + oyuncu sistemi"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "Mobile")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[editor_plugins]

enabled=PackedStringArray("res://addons/terrain_3d/plugin.cfg")

