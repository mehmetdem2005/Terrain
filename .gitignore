# Godot 4 editor cache
.godot/

# TerrainBaker tarafindan uretilen veriler ("ARAZI HAZIRLA" butonu)
# Kaynak: heightmap/*.exr -> terrain/height.bin + terrain/cdlod_meta.json
/terrain/*.bin
/terrain/*.json

# Buyuk kaynak heightmap (depoya degil, yerelde tutulur)
/heightmap/*.exr

# Godot import metadata
*.import
