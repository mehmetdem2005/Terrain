# Godot 4 editor cache
.godot/

# TerrainBaker tarafindan uretilen veriler ("CHUNK OLUSTUR" butonu)
# Kaynak: heightmap/*.exr -> terrain/terrain_data.bin + terrain/terrain_meta.json
/terrain/terrain_data.bin
/terrain/terrain_meta.json

# Buyuk kaynak heightmap (depoya degil, yerelde tutulur)
/heightmap/*.exr

# Godot import metadata
*.import
